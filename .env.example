RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Guinee Multiservices <notifications@mscarte.com>
EMAIL_REPLY_TO=support@mscarte.com
ADMIN_EMAIL=admin@mscarte.com
# Email(s) qui reçoivent les alertes commandes (séparés par des virgules)
# Exemple : vous@gmail.com,support@mscarte.com
ADMIN_NOTIFICATION_EMAIL=

# Secret API (signature anti-bot commandes — générez une chaîne aléatoire longue)
API_SECRET=changez-moi-secret-aleatoire-tres-long

# Cloudflare Turnstile (optionnel — renforce la protection anti-robot)
# Dashboard : https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Mot de passe admin (serveur uniquement — jamais dans le code source)
ADMIN_PASSWORD=changez-moi-mot-de-passe-fort

# Upstash Redis (Vercel Marketplace → Redis) — stockage partagé des commandes
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# URL publique du site (obligatoire pour les passes wallet)
SITE_URL=https://mscarte.com

# --- Apple Wallet (PassKit) ---
# 1. developer.apple.com → Certificates → Pass Type ID (ex: pass.com.mscarte.multiservice)
# 2. Créer un certificat « Pass Type ID » et exporter en .p12
# 3. Télécharger le certificat WWDR G4 (Apple Worldwide Developer Relations)
# 4. Encoder en base64 : base64 -i cert.p12 | pbcopy
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_TYPE_ID=pass.com.mscarte.multiservice
APPLE_PASS_CERT_PASSWORD=mot-de-passe-export-p12
APPLE_PASS_CERT_P12_BASE64=
APPLE_WWDR_CERT_BASE64=
# Alternative PEM (sans P12) :
# APPLE_PASS_SIGNER_CERT_BASE64=
# APPLE_PASS_SIGNER_KEY_BASE64=

# --- Google Wallet ---
# Prérequis :
# 1. https://console.cloud.google.com → créer un projet → activer « Google Wallet API »
# 2. https://pay.google.com/business/console → récupérer l'Issuer ID (numérique)
# 3. Google Cloud → IAM → Comptes de service → créer → clé JSON
# 4. Dans la console Google Pay, associer le compte de service comme utilisateur développeur
# 5. Définir SITE_URL (HTTPS) — utilisé comme origine autorisée du pass
#
# Option A — JSON sur une seule ligne (échapper les guillemets si besoin) :
GOOGLE_WALLET_ISSUER_ID=3388000000000000000
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"votre-projet","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"wallet@votre-projet.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
#
# Option B — JSON encodé en base64 (recommandé sur Vercel, évite les problèmes d'échappement) :
# base64 -i service-account.json | tr -d '\n' | pbcopy
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_BASE64=
#
# Identifiant de la classe de carte (suffixe libre, stable en production) :
GOOGLE_WALLET_CLASS_SUFFIX=guinee_multiservices_card
#
# Vérification après déploiement :
# GET https://votre-domaine.com/api/wallet-health
# GET https://votre-domaine.com/api/wallet-health?test=google
