RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Guinee Multiservices <notifications@mscarte.com>
EMAIL_REPLY_TO=support@mscarte.com
ADMIN_EMAIL=admin@mscarte.com
# Email(s) qui reçoivent les alertes commandes (séparés par des virgules)
# Exemple : vous@gmail.com,support@mscarte.com
ADMIN_NOTIFICATION_EMAIL=

# Secret API (signature anti-bot commandes — générez une chaîne aléatoire longue)
API_SECRET=changez-moi-secret-aleatoire-tres-long

# Cloudflare Turnstile (optionnel — renforce la protection anti-robot)
# Dashboard : https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Mot de passe admin (serveur uniquement — jamais dans le code source)
ADMIN_PASSWORD=changez-moi-mot-de-passe-fort

# Upstash Redis (Vercel Marketplace → Redis) — stockage partagé des commandes
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# URL publique du site (obligatoire pour les passes wallet)
SITE_URL=https://mscarte.com

# --- Apple Wallet (PassKit) ---
# 1. developer.apple.com → Certificates → Pass Type ID (ex: pass.com.mscarte.multiservice)
# 2. Créer un certificat « Pass Type ID » et exporter en .p12
# 3. Télécharger le certificat WWDR G4 (Apple Worldwide Developer Relations)
# 4. Encoder en base64 : base64 -i cert.p12 | pbcopy
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_TYPE_ID=pass.com.mscarte.multiservice
APPLE_PASS_CERT_PASSWORD=mot-de-passe-export-p12
APPLE_PASS_CERT_P12_BASE64=
APPLE_WWDR_CERT_BASE64=
# Alternative PEM (sans P12) :
# APPLE_PASS_SIGNER_CERT_BASE64=
# APPLE_PASS_SIGNER_KEY_BASE64=

# --- Google Wallet ---
# 1. console.cloud.google.com → activer « Google Wallet API »
# 2. pay.google.com/business/console → obtenir l'Issuer ID
# 3. Créer un compte de service JSON et coller le contenu complet ci-dessous
GOOGLE_WALLET_ISSUER_ID=3388000000000000000
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_WALLET_CLASS_SUFFIX=guinee_multiservices_card
